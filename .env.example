# =============================================================================
# Griote Platform — Production Environment Variables
# =============================================================================
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill every CHANGE_ME value
#   3. NEVER commit .env to git
#
# USED BY:
#   - docker-compose.prod.yml  (root — full production stack)
#
# FOR DEVELOPMENT:
#   - Use ./backend/.env  (already configured for local Docker)
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# Public URL of the frontend (used for CORS and email links)
FRONTEND_URL=https://griote.org

# -----------------------------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------------------------
DB_USER=griote
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=griote

# Connection URI — built automatically from values above; do not change format
DB_URI=postgres://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# -----------------------------------------------------------------------------
# Authentication — JWT
# Generate a secret with:  openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_TOKEN_EXPIRES_IN=1h

# bcrypt rounds — 12 is a good balance between security and performance
BCRYPT_SALT=12

# -----------------------------------------------------------------------------
# Email — SMTP
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# For Hostinger/other: use the SMTP credentials from your hosting panel
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=CHANGE_ME@gmail.com
MAIL_PASSWORD=CHANGE_ME_APP_PASSWORD

# "Display Name" <address> format
EMAIL_FROM="Griote Foundation" <no-reply@griote.org>

# -----------------------------------------------------------------------------
# MinIO — S3-compatible object storage
# Generate strong random keys — minimum 8 chars for access, 32+ for secret
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_SECRET_KEY_MINIMUM_32_CHARS

MINIO_BUCKET=griote

# Base URL for public file access (usually the frontend URL)
MINIO_PUBLIC_URL=https://griote.org

# -----------------------------------------------------------------------------
# Logging
# Levels: error | warn | info | debug
# -----------------------------------------------------------------------------
LOG_LEVEL=info
