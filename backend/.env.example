# =============================================================================
# Backend — Environment Variables Template
# =============================================================================
#
# DEVELOPMENT SETUP:
#   cp .env.example .env
#   # Values below are already correct for the Docker dev environment
#   # Just add your SMTP credentials if you want email verification
#
# PRODUCTION:
#   Use the root-level .env.example instead:
#   cp ../.env.example ../.env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Frontend origin — used for CORS and email redirect links
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Database — PostgreSQL
# (matches docker-compose.dev.yml default credentials)
# -----------------------------------------------------------------------------
DB_USER=griote
DB_PASSWORD=griote
DB_NAME=griote
DB_URI=postgres://griote:griote@postgres:5432/griote

# -----------------------------------------------------------------------------
# Authentication — JWT
# In production: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-chars

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_TOKEN_EXPIRES_IN=1h
BCRYPT_SALT=12

# -----------------------------------------------------------------------------
# Email — SMTP
# For local dev: use Ethereal (https://ethereal.email) — no real emails sent
# Create a free account and paste the credentials below
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
EMAIL_FROM="Griote Dev" <dev@griote.local>

# -----------------------------------------------------------------------------
# MinIO — Object storage
# (matches docker-compose.dev.yml default credentials)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=griote
MINIO_PUBLIC_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Logging
# Levels: error | warn | info | debug
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
