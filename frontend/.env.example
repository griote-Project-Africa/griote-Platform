# =============================================================================
# Frontend — Environment Variables Template
# =============================================================================
#
# Vite loads env files in this priority order (highest first):
#   .env.local            — local overrides, always gitignored
#   .env.development      — when running: pnpm dev
#   .env.production       — when running: pnpm build
#   .env                  — default fallback
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.
#
# DEVELOPMENT:  cp .env.example .env.development
# PRODUCTION:   cp .env.example .env.production  (then update the URL)
# =============================================================================

# Backend API base URL — must NOT have a trailing slash
# Development:  http://localhost:3000/api
# Production:   https://api.griote.org/api
VITE_API_BASE_URL=http://localhost:3000/api

# Application environment label (optional, used for debugging)
VITE_APP_ENV=development
